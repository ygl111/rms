      "tail_signature_offset": -2,
      "has_crc": true,
      "crc_offset": -4,
      "crc_size": 2,
      "crc_endianness": "little"
    },
    "dp_protocol_v2": {
      "header_size": 44,
      "msg_id_field": "msg_id",
      "msg_id_offset": 6,
      "msg_id_size": 2,
      "msg_id_endianness": "little",
      "length_field": "msg_body_len",
      "length_offset": 3,
      "length_size": 2,
      "length_endianness": "little",
